# --- Включение адаптеров ---
ENABLE_TELEGRAM=1
ENABLE_AVITO=1
ENABLE_VK=0

# --- LLM / Ollama ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# --- Telegram ---
# Можно использовать TELEGRAM_TOKEN или BOT_TOKEN (оба поддерживаются)
TELEGRAM_TOKEN=123456:ABCDEF
CALLCENTER_CHAT_ID=-1001234567890
TG_DEBOUNCE_DELAY=1.2
TG_PROMO_IMAGE_PATH=data/promo_tg.jpg

# --- Avito ---
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_USER_ID=
AVITO_TOKEN_PATH=data/avito_tokens.json
AVITO_POLL_INTERVAL=3
AVITO_ALLOWED_TITLES=Натяжные потолки. 2-й и 3-й потолок в подарок
AVITO_DEBUG=0

# --- VK ---
VK_GROUP_TOKEN=
VK_GROUP_ID=
VK_TEST_USER_ID=
VK_DEBUG=0
VK_DEBOUNCE_DELAY=1.2

# --- Поведение бота ---
# Можно переопределить системный промпт и длину истории
SYSTEM_PROMPT=
MAX_HISTORY=20
